# Copy to .env and fill in before running `npm start`.

# MongoDB connection URI (use Atlas or a local mongod)
MONGO_URI=mongodb://127.0.0.1:27017/hefflhoff

# Secret used to sign JWTs — replace with a random long string in production
JWT_SECRET=change_me_to_a_long_random_string_before_deploying

# Port the API listens on
PORT=5001

# Allowed CORS origin for the web game (or "*" in dev)
CORS_ORIGIN=*
