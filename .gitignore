android/key.properties
android/app/google-services.json
android/app/*.jks
android/app/*.keystore
*.apk
*.aab
*.idsig

# iOS / Capacitor (future-proofing)
ios/App/build/
ios/App/Pods/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# logs / runtime
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# misc
.cache/
.tmp/
coverage/
